# Copy to `.env` in this folder or to the repo root `.env` (both are loaded).
# Never commit real keys.

# TheCatAPI — optional; improves rate limits. https://thecatapi.com/
# If TheCatAPI is unavailable, the server falls back to Cataas (no key).
CAT_API_KEY=

# TMDB v3 — optional if you use Bearer token below.
TMDB_API_KEY=

# TMDB read access token (JWT) — Bearer auth; https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=
